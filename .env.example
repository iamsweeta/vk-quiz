DATABASE_URL="postgresql://quizpulse:quizpulse@localhost:5433/quizpulse?schema=public"
AUTH_SECRET="change-this-secret-in-production"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_REALTIME_URL="http://localhost:4000"

# mailpit | smtp | resend
EMAIL_PROVIDER="mailpit"
EMAIL_FROM="VK Quiz <no-reply@quizpulse.local>"
EMAIL_REQUIRE_VERIFICATION="true"

# Mailpit local inbox: http://localhost:8025
MAILPIT_HOST="localhost"
MAILPIT_PORT="1025"

# Real SMTP example: Gmail/Yandex/Mail.ru/hosting SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password"

# Optional production email provider
RESEND_API_KEY=""

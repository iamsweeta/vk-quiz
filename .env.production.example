# VK Quiz production environment example
# Copy only the needed values into Vercel / Render environment variables.

# PostgreSQL database from Neon/Supabase/Railway/etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Generate a long random value, for example: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-secret"

# Public web URL. Use your Vercel domain or your real custom domain.
APP_URL="https://vk-quiz.vercel.app"

# Public realtime server URL from Render/Fly/Railway.
NEXT_PUBLIC_REALTIME_URL="https://vk-quiz-realtime.onrender.com"

# Email verification
EMAIL_REQUIRE_VERIFICATION="true"
EMAIL_FROM="VK Quiz <noreply@your-domain.com>"

# Option A: Brevo SMTP, free enough for MVP
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-brevo-login@example.com"
SMTP_PASSWORD="your-brevo-smtp-key"

# Option B: Resend API instead of SMTP
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"

# Realtime server only
# Render provides PORT automatically. WEB_ORIGIN can contain multiple comma-separated origins.
WEB_ORIGIN="https://vk-quiz.vercel.app,https://your-domain.com"

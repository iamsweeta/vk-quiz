generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  ORGANIZER
  ADMIN
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  TEXT
  IMAGE
}

enum AnswerMode {
  SINGLE
  MULTIPLE
}

enum RoomStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum QuizVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  role            UserRole          @default(PARTICIPANT)
  mascotType      String            @default("PULSE_BOT")
  mascotColor     String            @default("cyan")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  quizzes         Quiz[]            @relation("QuizOwner")
  roomsHosted     Room[]            @relation("HostedRooms")
  participations  RoomParticipant[]
  ratings         QuizRating[]

  @@index([role])
  @@index([emailVerifiedAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Category {
  id      String @id @default(cuid())
  name    String @unique
  icon    String?
  quizzes Quiz[]
}

model Quiz {
  id                  String         @id @default(cuid())
  title               String
  description         String?
  coverImageUrl       String?
  defaultQuestionTime Int            @default(30)
  status              QuizStatus     @default(DRAFT)
  visibility          QuizVisibility @default(PRIVATE)
  accessCode          String?        @unique
  ownerId             String
  categoryId          String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  playCount           Int            @default(0)
  ratingCount         Int            @default(0)
  ratingSum           Int            @default(0)
  ratingAverage       Float          @default(0)

  owner               User           @relation("QuizOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  category            Category?      @relation(fields: [categoryId], references: [id])
  questions           Question[]
  rooms               Room[]
  ratings             QuizRating[]

  @@index([ownerId])
  @@index([status])
  @@index([visibility])
  @@index([accessCode])
  @@index([ratingAverage])
  @@index([playCount])
}

model Question {
  id          String        @id @default(cuid())
  quizId      String
  type        QuestionType  @default(TEXT)
  answerMode  AnswerMode    @default(SINGLE)
  text        String
  imageUrl    String?
  timeLimit   Int           @default(30)
  points      Int           @default(1000)
  order       Int           @default(0)

  quiz        Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     AnswerOption[]
  submissions AnswerSubmission[]

  @@index([quizId])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizRating {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  value     Int
  createdAt DateTime @default(now())

  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
  @@index([quizId])
  @@index([userId])
  @@index([value])
}

model Room {
  id                String            @id @default(cuid())
  code              String            @unique
  quizId            String
  hostId            String
  status            RoomStatus        @default(WAITING)
  currentQuestionId String?
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime          @default(now())

  quiz              Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  host              User              @relation("HostedRooms", fields: [hostId], references: [id], onDelete: Cascade)
  participants      RoomParticipant[]
  submissions       AnswerSubmission[]

  @@index([code])
  @@index([quizId])
  @@index([hostId])
}

model RoomParticipant {
  id            String             @id @default(cuid())
  roomId        String
  userId        String?
  nickname      String
  score         Int                @default(0)
  socketId      String?
  joinedAt      DateTime           @default(now())

  room          Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  submissions   AnswerSubmission[]

  @@index([roomId])
  @@index([userId])
}

model AnswerSubmission {
  id                String          @id @default(cuid())
  roomId            String
  participantId     String
  questionId        String
  selectedOptionIds String[]
  isCorrect         Boolean
  scoreAwarded      Int             @default(0)
  responseTimeMs    Int             @default(0)
  submittedAt       DateTime        @default(now())

  room              Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  participant       RoomParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question          Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([roomId, participantId, questionId])
  @@index([roomId])
  @@index([participantId])
  @@index([questionId])
}
